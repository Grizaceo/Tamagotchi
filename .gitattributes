# Normalizar todos los archivos de texto a LF en el repositorio
* text=auto eol=lf

# Forzar LF explícitamente en archivos de código
*.ts   text eol=lf
*.js   text eol=lf
*.json text eol=lf
*.yaml text eol=lf
*.yml  text eol=lf
*.md   text eol=lf
*.py   text eol=lf
*.css  text eol=lf
*.html text eol=lf

# Binarios — no tocar
*.png  binary
*.jpg  binary
*.gif  binary
*.ico  binary
*.woff binary
*.woff2 binary
